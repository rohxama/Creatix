{
  "expo": {
    "name": "Creatix Cafe",
    "slug": "creatix-cafe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "creatixcafe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B341A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.creatix.cafe"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#6B341A"
      },
      "package": "com.creatix.cafe"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-image",
      "expo-font",
      "expo-splash-screen",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}